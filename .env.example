# Wedding Website Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ncuffceyfgjccejxjvwa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email — Resend (preferred for gift thank-you from hello@laurensandmonica.com)
# https://resend.com/api-keys — verify laurensandmonica.com domain first
RESEND_API_KEY=

# Email — Fastmail SMTP (fallback if RESEND_API_KEY is not set)
# Create an app-specific password in Fastmail:
# Settings > Privacy & Security > Integrations > New App Password
FASTMAIL_SMTP_USER=wedding@laurensandmonica.com
FASTMAIL_SMTP_PASSWORD=

# Optional override for contributor thank-you From header
# GIFT_THANK_YOU_FROM="Laurens & Monica" <hello@laurensandmonica.com>

# Webhook Security
# Generate a random secret: openssl rand -hex 32
WEBHOOK_SECRET=

# PayPal (confirmed PayPal gift emails — bank uses click notification only)
# Create app: https://developer.paypal.com/dashboard/applications
# Webhook URL: https://laurensandmonica.com/api/webhooks/paypal
# Subscribe to: PAYMENT.CAPTURE.COMPLETED, PAYMENTS.PAYMENT.CREATED
# Both PayPal + bank send email when guest clicks; PayPal sends a second email when paid.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# live (default) or sandbox
PAYPAL_MODE=live

# Google Places API (for hotel ratings on Accommodations page)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Places API: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# Google Maps (optional - for embedded map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe (for honeymoon fund - add when ready)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
